

set_io CLK100MHz J3 
set_io vga_r[2]         E4 # 
set_io vga_g[2]         B2 # 
set_io vga_b[2]         F5 # 


# the test board has only one bit per channel so
# these are just parked here
set_io vga_r[1]         N5 #
set_io vga_r[0]         T2 # 
set_io vga_g[1]         R3 # 
set_io vga_g[0]         R5 # 
set_io vga_b[1]         R4 # 
set_io vga_b[0]         M7 # 


set_io vga_hs H1 # B1
set_io vga_vs G1 # C1 

set_io ps2_clk G3
set_io ps2_data E2
